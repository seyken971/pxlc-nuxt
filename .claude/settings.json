{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py .claude/hooks/post-edit-checks.py",
            "timeout": 90,
            "statusMessage": "Vérifications post-édition (validate-content / ESLint)…"
          }
        ]
      }
    ]
  }
}
