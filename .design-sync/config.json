{
  "projectId": "f2703de8-2aa9-4ab1-8822-8dd70be7a752",
  "pkg": "pxlc-nuxt",
  "globalName": "PxlcDS",
  "shape": "package",
  "buildCmd": "npm run build:ce",
  "cssEntry": "dist-ce/pxlc-ds.css",
  "runtimeFontPrefixes": ["Plus Jakarta Sans", "Lora"],
  "overrides": {
    "PxlcMarkSeparator": { "cardMode": "column" },
    "PxlcPixelStrip": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "PxlcMark": "app/components/PxlcMark.vue",
    "PxlcInput": "app/components/PxlcInput.vue",
    "PxlcMarkSeparator": "app/components/PxlcMarkSeparator.vue",
    "PxlcPixelCorner": "app/components/PxlcPixelCorner.vue",
    "PxlcPixelStrip": "app/components/PxlcPixelStrip.vue",
    "PxlcLinkout": "lib/PxlcLinkout.vue",
    "PxlcLockup": "lib/PxlcLockup.vue"
  },
  "readmeHeader": ".design-sync/conventions.md",
  "dtsPropsFor": {
    "PxlcMark": "size?: number; decorative?: boolean",
    "PxlcInput": "id: string; label: string; modelValue?: string; type?: string; placeholder?: string; rows?: number; required?: boolean; autocomplete?: string",
    "PxlcMarkSeparator": "",
    "PxlcPixelCorner": "",
    "PxlcPixelStrip": "count?: number; accentAt?: number",
    "PxlcLinkout": "to: string",
    "PxlcLockup": "size?: 'sm' | 'md' | 'lg'; to?: string"
  }
}
