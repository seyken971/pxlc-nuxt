{
  "name": "pxlc-nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "gen:tokens": "node scripts/generate-tokens.mjs",
    "design": "node scripts/export-design.mjs",
    "ds-lint": "node scripts/ds-lint.mjs",
    "validate-content": "node scripts/validate-content.mjs",
    "prebuild": "npm run gen:tokens && npm run design && npm run ds-lint && npm run validate-content",
    "pregenerate": "npm run gen:tokens && npm run design && npm run ds-lint && npm run validate-content",
    "predev": "npm run gen:tokens && npm run design",
    "postbuild": "node scripts/prune-public.mjs",
    "postgenerate": "node scripts/prune-public.mjs",
    "a11y": "node scripts/a11y-audit.mjs",
    "a11y:runtime": "node scripts/a11y-runtime.mjs",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:ce": "vite build --config vite.ce.config.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.113",
    "@iconify-json/simple-icons": "^1.2.86",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/seo": "^5.3.0",
    "@takumi-rs/core": "^1.8.6",
    "better-sqlite3": "^12.11.1",
    "nuxt": "^4.4.8",
    "puppeteer": "^25.1.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint": "^1.16.0",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "nuxt-link-checker": "^5.1.1",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  }
}
